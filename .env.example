# .env.example

# eBay API Credentials
EBAY_CLIENT_ID=your_ebay_client_id
EBAY_CLIENT_SECRET=your_ebay_client_secret

# MongoDB Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/auction-scraper?retryWrites=true&w=majority

# Application Settings
APP_ENV=development
APP_DEBUG=true
APP_PORT=3000